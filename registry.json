      "name": "cli-web-futbin",
      "website": "futbin.com",
      "protocol": "HTML + JSON API",
      "auth": "none",
      "directory": "futbin/agent-harness",
      "namespace": "cli_web.futbin",
      "commands": [
        "players search",
        "players get",
        "players list",
        "players compare",
        "players price-history",
        "players versions",
        "market index",
        "market popular",
        "market latest",
        "market cheapest",
        "market movers",
        "market fodder",
        "market analyze",
        "market scan",
        "market arbitrage",
        "sbc list",
        "sbc get",
        "evolutions list",
        "evolutions get",
        "config set",
        "config show",
        "config reset"
      ],
      "install": "pip install -e futbin/agent-harness",
      "canary": [
        [
          "market",
          "index",
          "--json"
        ]
      ],
      "display_website": "FUTBIN",
      "skill": ".claude/skills/futbin-cli/SKILL.md",
      "description": "EA FC player database \u2014 search, compare, prices, market analysis, arbitrage, trading signals"
    },
